{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.csr.html",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "fonts",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|otf|ttf|woff|woff2)"
        ]
      }
    },
    {
      "name": "media",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(jpg|jpeg|png|apng|webp|avif|gif)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-fresh",
      "urls": [
        "https://api.scholaro.app/parents/me/children",
        "https://api.scholaro.app/activities/feed*",
        "https://api.scholaro.app/daily-logs*",
        "https://api.scholaro.app/attendance*",
        "https://api.scholaro.app/parents/student/*/fees*",
        "https://api.scholaro.app/fees*"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "1h",
        "timeout": "3s"
      }
    },
    {
      "name": "api-cached",
      "urls": [
        "https://api.scholaro.app/classes*",
        "https://api.scholaro.app/sections*"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 30,
        "maxAge": "1h"
      }
    },
    {
      "name": "supabase-images",
      "urls": [
        "https://iunouihhapyioadxtece.supabase.co/storage/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 100,
        "maxAge": "7d"
      }
    }
  ]
}
